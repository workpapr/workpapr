{
  "name": "@workpapr/core",
  "version": "0.1.0",
  "description": "The provider-neutral audit platform. We don't use AI to audit — we make AI auditable.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "workpapr": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./scanner": "./dist/scanner/index.js",
    "./scanner/types": "./dist/scanner/types.js",
    "./analyzer": "./dist/analyzer/pipeline.js",
    "./analyzer/types": "./dist/analyzer/types.js",
    "./analyzer/trace-hook": "./dist/analyzer/trace-hook.js",
    "./ai/provider": "./dist/ai/provider.js",
    "./ai/types": "./dist/ai/types.js",
    "./ai/cache": "./dist/ai/cache.js",
    "./ai/audit-log": "./dist/ai/audit-log.js",
    "./ai/providers/mlx": "./dist/ai/providers/mlx.js",
    "./ai/providers/ollama": "./dist/ai/providers/ollama.js",
    "./workpaper": "./dist/workpaper/generator.js",
    "./workpaper/types": "./dist/workpaper/types.js",
    "./policy": "./dist/policy/engine.js",
    "./policy/defaults": "./dist/policy/defaults.js",
    "./training/types": "./dist/training/types.js",
    "./findings/persistence": "./dist/findings/persistence.js",
    "./findings/types": "./dist/findings/types.js",
    "./inventory/builder": "./dist/inventory/builder.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "audit",
    "compliance",
    "llm",
    "governance",
    "sox",
    "eu-ai-act",
    "workpapr"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/workpapr/workpapr"
  },
  "homepage": "https://workpapr.ai",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "glob": "^11.0.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
